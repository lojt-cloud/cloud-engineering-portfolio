# =============================================
# .env.example
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file (it's already in .gitignore).
# Only fill in the section(s) relevant to THIS project.
# =============================================

# ---------- AWS ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
# AWS_SESSION_TOKEN=        # only needed if using temporary/STS credentials

# ---------- Azure ----------
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# ---------- Google Cloud (GCP) ----------
GOOGLE_APPLICATION_CREDENTIALS=     # path to your service account JSON key file
GCP_PROJECT_ID=
GCP_REGION=

# ---------- Terraform-specific (optional) ----------
# TF_VAR_environment=dev
# TF_VAR_project_name=

# ---------- Other secrets used in this project ----------
# VAULT_TOKEN=
# GRAFANA_API_KEY=
